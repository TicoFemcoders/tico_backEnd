    class EM1,EM3,EM4,EM5,EM_ESTADO,EM_COD1,EM_COD2,FORGOT_EM_COD1,FORGOT_EM_COD2 email
    class EM_REACT_EMP,EM_REACT_ADM email
    class FORGOT_ERR,UREMP_ERR,UADM_ERR,ERR_INACT,EBLOCK email
    class FORGOT_ERR,UREMP_ERR,UADM_ERR,ERR_INACT warn
    class TIC_OK,TIC_C,ACT_OK,RESET_OK,UDEL_OK,UREMP_OK,UADM_OK,EENAB,REACT_EMP,REACT_ADM,UEDIT_OK,UREACT,EDESACT_OK ok
    class START,LOGOUT_E,LOGOUT_A terminal
    class CRED,ROL,OPC_PRIOR,VAL,CERR,UELIM_CHK,ETOGGLE,ES_ASIG,TIC_CERR_EMP,TIC_CERR_ADM,COD_VAL,PASS_VAL,FORGOT_EXIST,RESET_VAL,UREMP_VAL,UADM_VAL,SIN_ASIG,ACT_CHK,UREACT_CHK,EDESACT decision
    class FIL,F1,F2,F3,F4,F5 filter
    class ACT_FORM,REENVIAR,RESET_FORM,RESET_REENVIAR,FORGOT_EMAIL activation
