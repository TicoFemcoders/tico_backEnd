         flowchart TD

    START([Inicio])
    START --> LOGIN[Pantalla de login]
    LOGIN --> FORGOT[He olvidado mi contraseña]
    LOGIN --> CRED{Credenciales válidas?}
    CRED -->|No| ERR[Error de credenciales]
    ERR --> LOGIN
    CRED -->|Sí| ACT_CHK{¿Cuenta activa?}
    ACT_CHK -->|No| ERR_INACT[Error: cuenta no activada]
    ERR_INACT --> LOGIN
    ACT_CHK -->|Sí| ROL{Rol del usuario?}
    ROL -->|Empleado| EMP_DASH
    ROL -->|Admin| ADM_DASH

    subgraph RESET ["🔑 Olvidé mi contraseña"]
        FORGOT --> FORGOT_EMAIL[Insertar email]
        FORGOT_EMAIL --> FORGOT_EXIST{Email existe en BD y activo?}
        FORGOT_EXIST -->|No| FORGOT_ERR[Email no encontrado]
        FORGOT_ERR --> FORGOT_EMAIL
        FORGOT_EXIST -->|Sí — rate limit 3/15min| FORGOT_EM_COD1[Email 1: código temporal 6 dígitos válido 30 min]
        FORGOT_EXIST -->|Sí| FORGOT_EM_COD2[Email 2: link de reset /reset-password?email=...]
        FORGOT_EM_COD1 --> RESET_FORM[Formulario: código y nueva contraseña y confirmar]
        FORGOT_EM_COD2 --> RESET_FORM
        RESET_FORM --> RESET_VAL{Código válido y contraseñas OK?}
        RESET_VAL -->|No / Expirado| RESET_REENVIAR[Solicitar nuevo código → invalida anteriores y reenvía Email 1]
        RESET_REENVIAR --> FORGOT_EM_COD1
        RESET_VAL -->|Sí| RESET_OK[Contraseña actualizada]
        RESET_OK --> LOGIN_RESET["Login ?reset=1 → banner: Contraseña actualizada"]
        LOGIN_RESET --> LOGIN
    end

    subgraph ACTIVACION ["🔐 Activación de cuenta"]
        UCREAR_EXT[Admin crea usuario — isActive=false sin contraseña real]
        UCREAR_EXT --> EM_COD1[Email 1: código secreto 6 dígitos válido 30 min]
        UCREAR_EXT --> EM_COD2[Email 2: link de activación /activation?email=...]
        EM_COD1 --> ACT_FORM[Formulario: código y nueva contraseña y confirmar]
        EM_COD2 --> ACT_FORM
        ACT_FORM --> COD_VAL{Código válido y no expirado?}
        COD_VAL -->|No / Expirado| REENVIAR[Solicitar nuevo código → invalida anteriores y reenvía Email 1]
        REENVIAR --> EM_COD1
        COD_VAL -->|Sí| PASS_VAL{Contraseñas coinciden y válidas?}
        PASS_VAL -->|No| ACT_FORM
        PASS_VAL -->|Sí| ACT_OK[Cuenta activada: isActive = true]
        ACT_OK --> LOGIN_ACT["Login ?activated=1 → banner: Cuenta activada"]
        LOGIN_ACT --> LOGIN
    end

    subgraph EMPLEADO ["👤 Empleado — /my-tickets"]
        EMP_DASH[Panel: mis tickets más recientes primero DESC]
        EMP_DASH --> VER[Ver detalle del ticket — /detail-ticket/:id]
        VER --> TIC_CERR_EMP{¿Ticket cerrado?}
        TIC_CERR_EMP -->|No| HIST[Ver historial de mensajes del hilo]
        HIST --> EMP_MSG[Escribir mensaje en el hilo]
        EMP_MSG --> NOTIF_ADM_MSG[Notificación interna al admin asignado]
        NOTIF_ADM_MSG --> EMP_DASH
        TIC_CERR_EMP -->|Sí| REACT_EMP[Reactivar ticket — estado OPEN]
        REACT_EMP --> EM_REACT_EMP[Email al empleado: ticket reactivado]
        EM_REACT_EMP --> EMP_DASH
        EMP_DASH --> NUEVO[Crear nuevo ticket — /tickets]
        NUEVO --> FORM["Formulario: título y descripción y al menos 1 etiqueta activa"]
        FORM --> OPC_PRIOR{Añadir prioridad?}
        OPC_PRIOR -->|No — default MEDIUM| VAL
        OPC_PRIOR -->|Sí| PRIOR[LOW / MEDIUM / HIGH / CRITICAL]
        PRIOR --> VAL{Campos obligatorios OK?}
        VAL -->|No| ERR_F[Error de validación]
        ERR_F --> FORM
        VAL -->|Sí| TIC_OK[Ticket creado: status OPEN]
        TIC_OK --> EM1[Email al empleado: confirmación de creación]
        EM1 --> EMP_DASH
        EMP_DASH --> LOGOUT_E[Cerrar sesión]
    end

    subgraph ADMIN_TK ["🎫 Admin — Tickets — /all-tickets o /assigned"]
        ADM_DASH[Panel: sin asignar primero luego por fecha DESC más recientes]
        ADM_DASH --> FIL[Multifiltro combinable]
        FIL --> F1[Por asignación: sin asignar / mis tickets / todos]
        FIL --> F2[Por estado: OPEN / IN_PROGRESS / CLOSED]
        FIL --> F3[Por prioridad: CRITICAL / HIGH / MEDIUM / LOW]
        FIL --> F4[Por etiqueta]
        FIL --> F5[Por fecha: más reciente primero DESC]
        F1 --> DET
        F2 --> DET
        F3 --> DET
        F4 --> DET
        F5 --> DET
        ADM_DASH --> DET[Ver detalle del ticket — /detail-ticket/:id]
        DET --> TIC_CERR_ADM{¿Ticket CLOSED?}

        TIC_CERR_ADM -->|Sí| REACT_ADM[Reactivar ticket — estado IN_PROGRESS]
        REACT_ADM --> EM_REACT_ADM[Email al empleado: ticket reactivado]
        EM_REACT_ADM --> DET

        TIC_CERR_ADM -->|No| SIN_ASIG{¿Sin admin asignado?}
        SIN_ASIG -->|Sí| ASIG_SELF[Asignar admin al ticket]
        ASIG_SELF --> AUTO_IN_PROG[Ticket OPEN → IN_PROGRESS automáticamente]
        AUTO_IN_PROG --> NOTIF_ADMIN[Notificación interna al admin asignado]
        AUTO_IN_PROG --> EM_ESTADO[Email al empleado: estado del ticket cambió a En curso]
        NOTIF_ADMIN --> DET
        EM_ESTADO --> DET

        SIN_ASIG -->|No| ES_ASIG{¿Soy el admin asignado?}
        ES_ASIG -->|No| RASIG[Reasignar a otro admin — operación interna sin email al empleado]
        RASIG --> NOTIF_ADMIN2[Notificación interna al nuevo admin asignado]
        NOTIF_ADMIN2 --> DET

        ES_ASIG -->|Sí| ACC[Acciones disponibles]
        ACC --> ETQ[Cambiar o añadir etiquetas activas]
        ETQ --> DET
        ACC --> CPRI[Cambiar prioridad]
        CPRI --> EM3[Email al empleado creador: cambio de prioridad]
        EM3 --> DET
        ACC --> RESP[Escribir mensaje en el hilo del ticket]
        RESP --> EM4[Email al empleado creador: nueva actualización del hilo]
        EM4 --> DET
        ACC --> CERR{Cerrar ticket?}
        CERR -->|No| DET
        CERR -->|Sí| TIC_C[Ticket CLOSED — closedAt registrado]
        TIC_C --> EM5[Email al empleado creador: ticket cerrado]
        EM5 --> ADM_DASH
    end

    subgraph ADMIN_USR ["👥 Admin — Usuarios — /users"]
        ADM_DASH --> ULIST[Listado de usuarios activos e inactivos]
        ULIST --> UCREAR[Crear usuario: nombre y email y rol]
        UCREAR --> UCREAR_EXT
        ULIST --> UEDIT[Editar usuario: nombre / email / roles]
        UEDIT --> UEDIT_OK[Usuario actualizado]
        UEDIT_OK --> ULIST
        ULIST --> UREACT_CHK{¿Usuario inactivo?}
        UREACT_CHK -->|Sí| UREACT[Reactivar cuenta: isActive = true]
        UREACT --> ULIST
        ULIST --> UELIM_CHK{Desactivar o eliminar usuario?}
        UELIM_CHK -->|Último admin del sistema| UBLOCK[Bloqueado: no se puede dejar sin admins]
        UBLOCK --> ULIST
        UELIM_CHK -->|Admin con tickets activos| UADM_MODAL[Obligatorio: email de otro admin para reasignar]
        UADM_MODAL --> UADM_VAL{Email existe en BD como admin activo?}
        UADM_VAL -->|No| UADM_ERR[Error: email no válido]
        UADM_ERR --> UADM_MODAL
        UADM_VAL -->|Sí| UADM_OK[Tickets y notificaciones reasignadas al nuevo admin]
        UADM_OK --> UDEL_OK[Usuario desactivado o eliminado]
        UELIM_CHK -->|Empleado con tickets abiertos| UREMP_MODAL[Opcional: email de otro empleado para reasignar]
        UREMP_MODAL --> UREMP_VAL{Email existe en BD como empleado activo?}
        UREMP_VAL -->|No| UREMP_ERR[Error: email no válido]
        UREMP_ERR --> UREMP_MODAL
        UREMP_VAL -->|Sí| UREMP_OK[Tickets reasignados al nuevo empleado]
        UREMP_OK --> UDEL_OK
        UELIM_CHK -->|Sin tickets activos| UDEL_OK
        UDEL_OK --> ULIST
    end

    subgraph ADMIN_ETQ ["🏷️ Admin — Etiquetas — /labels"]
        ADM_DASH --> ELIST[Listado de etiquetas: activas e inactivas]
        ELIST --> ECREAR[Crear etiqueta: nombre único y color hex]
        ECREAR --> ELIST
        ELIST --> EEDIT[Editar: nombre / color]
        EEDIT --> EACT_TK[Actualización automática en todos los tickets]
        EACT_TK --> ELIST
        ELIST --> ETOGGLE{Estado actual?}
        ETOGGLE -->|Activa| EDESACT{¿Tiene tickets activos?}
        EDESACT -->|Sí| EBLOCK[Bloqueado: hay tickets activos con esta etiqueta]
        EBLOCK --> ELIST
        EDESACT -->|No| EDESACT_OK[Etiqueta desactivada]
        EDESACT_OK --> ENOTA[Ya no aparece en filtros ni al crear tickets]
        ENOTA --> ELIST
        ETOGGLE -->|Inactiva| EENAB[Reactivar etiqueta]
        EENAB --> ELIST
    end

    subgraph NOTIF ["🔔 Notificaciones — Header campana"]
        NOTE_1["📌 Las notificaciones son TicketMessage con recipientId poblado"]
        NOTE_2["📌 Tipos: ticket asignado / reasignado / mensaje nuevo / apertura / cierre"]

        BELL[Campana: badge con nº de no leídas]
        EMP_DASH --> BELL
        ADM_DASH --> BELL

        BELL --> NPANEL[Panel scroll infinito: no leídas primero]
        NPANEL --> NITEM{Clicar notificación}
        NITEM --> NDET[Navegar al detalle del ticket]
        NDET --> NMARK[Marcar como leída]
        NMARK --> NITEM
        NPANEL --> NALL[Marcar todas como leídas — optimistic update]
        NALL --> NPANEL
    end

    ADM_DASH --> LOGOUT_A[Cerrar sesión]
    LOGOUT_E --> LOGIN
    LOGOUT_A --> LOGIN

